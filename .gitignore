# ── Dependencies ──────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ── NOTE: public/ and netlify/ are intentionally tracked ──────

# ── Environment & Secrets ──────────────────────────────────────
.env
.env.*
.env.local
.env.production
*.pem
*.key
*.cert
*.p12
secrets.json
credentials.json

# ── App Runtime Data (sensitive / local only) ──────────────────
checks.json
data/
uploads/

# ── Puppeteer / Chrome cache ───────────────────────────────────
.cache/
.local-chromium/

# ── OS & Editor junk ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp
*.swp

# ── IDE configs ────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Docker build artifacts ────────────────────────────────────
.dockerignore
