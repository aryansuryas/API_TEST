<!DOCTYPE html>
<html class="light" lang="en">
<head>
  <meta charset="utf-8"/>
  <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0" name="viewport"/>
  <title>API SENTINEL - Mission Control</title>
  
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;900&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "surface-variant": "#e4e4cc",
            "on-surface-variant": "#45464d",
            "primary-fixed": "#dae2fd",
            "surface-tint": "#565e74",
            "on-primary-container": "#7c839b",
            "primary-fixed-dim": "#bec6e0",
            "primary": "#000000",
            "on-tertiary": "#ffffff",
            "surface-container-high": "#eae1cc",
            "outline-variant": "#c6c6cd",
            "inverse-on-surface": "#f2f2d9",
            "on-secondary-fixed": "#00210c",
            "inverse-primary": "#bec6e0",
            "on-error-container": "#93000a",
            "inverse-surface": "#303221",
            "on-secondary-container": "#007439",
            "on-secondary": "#ffffff",
            "error-container": "#ffdad6",
            "secondary": "#006d36",
            "tertiary": "#000000",
            "on-tertiary-container": "#da5a5b",
            "tertiary-container": "#410006",
            "background": "#fdfbf7", /* refined cream */
            "surface-container-highest": "#f0ebde",
            "secondary-fixed": "#6dfe9c",
            "primary-container": "#131b2e",
            "surface-bright": "#fdfbf7",
            "surface": "#fdfbf7",
            "on-background": "#1b1d0e",
            "tertiary-fixed": "#ffdad8",
            "tertiary-fixed-dim": "#ffb3b0",
            "on-primary": "#ffffff",
            "surface-container": "#f4f1ea",
            "outline": "#76777d",
            "secondary-fixed-dim": "#4de082",
            "on-surface": "#1b1d0e",
            "on-secondary-fixed-variant": "#005227",
            "surface-container-lowest": "#ffffff",
            "on-primary-fixed": "#131b2e",
            "surface-container-low": "#faf8f2",
            "on-error": "#ffffff",
            "on-tertiary-fixed": "#410006",
            "secondary-container": "#6dfe9c",
            "on-tertiary-fixed-variant": "#881d24",
            "error": "#ba1a1a",
            "on-primary-fixed-variant": "#3f465c",
            "surface-dim": "#f5f0e6",
            "green-pip": "#10b981",
            "red-pip": "#ef4444",
            "amber-pip": "#f59e0b"
          },
          fontFamily: {
            "headline": ["Space Grotesk", "sans-serif"],
            "body": ["Inter", "sans-serif"],
            "mono": ["JetBrains Mono", "monospace"]
          }
        }
      }
    }
  </script>
  <style>
    .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    .glow-green { box-shadow: 0 0 12px #10b981; }
    .glow-error { box-shadow: 0 0 12px #ef4444; }
    .glow-amber { box-shadow: 0 0 12px #f59e0b; }
    .scanline {
      background: linear-gradient(to bottom, transparent 50%, rgba(19, 27, 46, 0.05) 50%);
      background-size: 100% 4px;
    }
    body { min-height: max(884px, 100dvh); overflow-x: hidden; }
    
    /* animations */
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .anim-fade { animation: slideUp 0.4s ease-out forwards; }
    
    @keyframes spin { 100% { transform: rotate(360deg); } }
    .spinning { animation: spin 1s linear infinite; }
  </style>
</head>
<body class="bg-background font-body text-on-surface min-h-screen pb-24 md:pb-0 font-medium tracking-tight">

  <!-- TopAppBar -->
  <header class="bg-[#fdfbf7] border-b border-primary-container/10 sm:border-none rounded-none w-full top-0 sticky z-50 shadow-sm sm:shadow-none">
    <div class="flex items-center justify-between px-6 py-4 w-full">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-slate-900 text-3xl">terminal</span>
        <h1 class="text-2xl sm:text-3xl font-black tracking-tighter text-primary font-headline uppercase tracking-widest break-words flex-wrap">API SENTINEL</h1>
      </div>
      <nav class="hidden md:flex gap-8">
        <a class="text-primary font-headline text-sm font-bold uppercase tracking-widest transition-colors duration-150 ease-in-out hover:bg-surface-container px-3 py-2 rounded-md" href="/">MONITOR</a>
      </nav>
      <div class="flex items-center gap-4">
        <div class="hidden sm:flex flex-col items-end">
          <span class="text-xs font-bold uppercase tracking-tight opacity-50">System Status</span>
          <span class="text-sm font-bold uppercase text-green-600 flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-green-500 glow-green"></span>
            Operational
          </span>
        </div>
      </div>
    </div>
    <div class="bg-[#131b2e] h-1 w-full relative overflow-hidden">
      <div class="absolute inset-0 bg-secondary-fixed w-1/4 animate-[slide_2s_ease-in-out_infinite]"></div>
    </div>
  </header>

  <style>
    @keyframes slide {
      0% { transform: translateX(-100%); }
      100% { transform: translateX(400%); }
    }
  </style>

  <main class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-12 space-y-8 sm:space-y-12">
    <!-- Add New Monitor Section -->
    <section class="grid grid-cols-1 lg:grid-cols-12 gap-0 border border-primary-container/10 rounded-sm overflow-hidden shadow-sm">
      <div class="lg:col-span-3 bg-primary-container p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-on-primary-container font-headline font-bold text-sm uppercase tracking-[0.2em] mb-3">Command_Entry</h2>
          <p class="text-on-primary-container/80 text-sm leading-relaxed font-semibold">INITIALIZE NEW PROTOCOL MONITORING SERVICE BY ENTERING DESTINATION ENDPOINT.</p>
        </div>
        <span class="material-symbols-outlined text-on-primary-container/20 text-6xl rotate-12 self-end mt-4 lg:mt-0">add_task</span>
      </div>
      
      <div class="lg:col-span-9 bg-surface-container-low p-8 sm:p-10">
        <form id="apiForm" class="flex flex-col md:flex-row items-end gap-6 w-full h-full">
          <div class="flex-1 w-full group">
            <label class="block text-xs font-bold uppercase tracking-widest text-primary mb-3">Endpoint Destination URL</label>
            <div class="relative">
              <input id="urlInput" required class="w-full bg-surface-container-highest border border-primary-container/10 focus:ring-2 focus:ring-primary text-primary font-mono text-base sm:text-lg p-5 placeholder:opacity-40 transition-all font-bold rounded-md" placeholder="https://api.v1.production.com/health" type="url"/>
              <div class="absolute right-5 top-1/2 -translate-y-1/2 flex gap-2">
                <span class="text-xs font-bold opacity-30">AUTO_TLS</span>
              </div>
            </div>
          </div>
          <button id="checkBtn" type="submit" class="w-full md:w-auto bg-primary text-on-primary px-10 py-5 font-headline font-bold text-sm uppercase tracking-[0.2em] hover:bg-slate-800 transition-all flex items-center justify-center gap-3 active:scale-[0.98] rounded-md">
            <span id="btnText">Start Scan</span>
            <span id="btnIcon" class="material-symbols-outlined text-base">rocket_launch</span>
          </button>
        </form>
      </div>
    </section>

    <!-- LIVE VALIDATION PANEL (Hidden by Default) -->
    <div id="liveResultPanel" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-0 border border-primary-container/10 rounded-sm overflow-hidden shadow-md anim-fade bg-white">
      <div class="lg:col-span-12 p-8 sm:p-10 bg-surface-container-low border-b border-primary-container/10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
          <h2 class="font-headline font-black text-xl md:text-2xl uppercase tracking-tight">Active Scan Result</h2>
          <span id="resTimestamp" class="text-xs font-bold font-mono text-primary/50 uppercase tracking-widest break-words"></span>
        </div>
        
        <div class="flex flex-col md:flex-row items-center gap-10">
          <div class="flex items-center gap-6 flex-1 w-full sm:w-auto">
            <div id="resDot" class="w-16 h-16 rounded-full flex items-center justify-center filter drop-shadow-sm shrink-0">
               <span class="material-symbols-outlined text-white text-3xl" id="resIcon">settings_ethernet</span>
            </div>
            <div>
              <p class="text-xs font-bold opacity-50 uppercase tracking-widest mb-2">Status Code</p>
              <h3 id="resCode" class="font-mono text-4xl sm:text-5xl font-black">200</h3>
            </div>
          </div>
          
          <div class="flex-1 w-full border-t md:border-t-0 md:border-l border-primary-container/10 pt-6 md:pt-0 pl-0 md:pl-10">
            <p class="text-xs font-bold opacity-50 uppercase tracking-widest mb-2">Latency</p>
            <h3 id="resLat" class="font-headline text-4xl sm:text-5xl font-black text-primary">0<span class="text-lg font-medium ml-2">ms</span></h3>
            <div class="w-full h-2 bg-surface-variant mt-4 rounded-full overflow-hidden">
                <div id="resLatBar" class="h-full bg-primary transition-all duration-500 ease-out" style="width: 0%"></div>
            </div>
          </div>
        </div>

        <div id="resErrBody" class="hidden mt-6 p-6 bg-error-container/20 border-l-4 border-error text-error font-mono text-sm font-bold leading-relaxed break-words shadow-sm"></div>

        <!-- Agentic Validation Engine -->
        <div id="agentUI" class="hidden mt-6 pt-6 border-t border-primary-container/10">
          <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
            <p class="text-xs font-bold font-headline uppercase text-error tracking-wider flex items-center gap-2">
              <span class="material-symbols-outlined text-base">warning</span> Service Down. Run Web Agent?
            </p>
            <button id="agentBtn" class="w-full sm:w-auto bg-[#ba1a1a] text-white px-6 py-3 rounded-sm text-xs font-bold font-headline uppercase tracking-widest hover:bg-[#93000a] transition-all flex items-center justify-center gap-2 shadow-sm active:scale-95">
              <span id="agentIcon" class="material-symbols-outlined text-sm">robot_2</span> 
              <span id="agentText">Validate Official Status</span>
            </button>
          </div>
          <div id="agentOut" class="hidden mt-4 p-4 bg-primary-container text-on-primary-container font-mono text-[11px] leading-relaxed max-h-48 overflow-y-auto scanline shadow-inner rounded-sm border border-black z-0"></div>
        </div>
      </div>
    </div>


    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 sm:gap-12">
      <!-- Active Monitors List (History view logic) -->
      <div class="lg:col-span-8 space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-center justify-between border-b border-primary-container/10 pb-6 gap-4">
          <div class="flex items-center gap-4">
            <span class="bg-primary-container text-on-primary-container px-4 py-2 text-xs font-bold tracking-widest rounded-md">TRANSMISSIONS</span>
            <h2 class="font-headline font-black text-xl sm:text-2xl uppercase tracking-tighter">Transmission Log</h2>
          </div>
          <span id="historyCountLabel" class="text-xs font-bold opacity-50 font-mono tracking-wide uppercase shrink-0">Records: <%= checks.length %> / 10</span>
        </div>

        <div class="space-y-4" id="historyContainer">
          <!-- EJS Loops over checks -->
          <% if (checks.length === 0) { %>
            <div class="p-10 text-center bg-surface-container-low border border-primary-container/10 border-dashed rounded-md">
              <span class="material-symbols-outlined text-5xl opacity-20 mb-3">satellite_alt</span>
              <p class="text-sm font-bold font-headline uppercase tracking-widest opacity-50">No Transmissions Recorded</p>
            </div>
          <% } else { %>
            <% checks.forEach(check => { %>
              <% const isUp = check.status === 'UP'; %>
              <div class="<%= isUp ? 'bg-surface-container-low hover:bg-surface-container-high' : 'bg-error-container/20 hover:bg-error-container/30' %> transition-all flex flex-col sm:flex-row items-stretch border border-primary-container/5 shadow-[0_1px_2px_rgba(0,0,0,0.02)] rounded-md">
                <div class="w-2 sm:w-2.5 <%= isUp ? 'bg-green-pip' : 'bg-error text-error' %> group-hover:w-3.5 transition-all rounded-l-md"></div>
                <div class="flex-1 p-6 sm:p-8 grid grid-cols-1 md:grid-cols-4 gap-4 sm:gap-8 items-center">
                  <div class="md:col-span-2 space-y-2">
                    <div class="flex items-center gap-3">
                      <span class="text-xs sm:text-sm font-black <%= isUp ? 'text-green-600' : 'text-error' %> uppercase tracking-widest"><%= check.status %></span>
                      <span class="text-xs text-on-surface/50 font-mono">ID:<%= check.id.substring(0,6) %></span>
                    </div>
                    <h3 class="font-mono text-sm sm:text-base font-bold truncate max-w-[200px] sm:max-w-full text-primary" title="<%= check.url %>"><%= check.url %></h3>
                  </div>
                  
                  <div class="flex items-center justify-start md:justify-center gap-5 border-t md:border-none border-primary-container/5 pt-4 md:pt-0">
                    <div class="w-3 h-3 rounded-full <%= isUp ? 'bg-green-pip glow-green' : 'bg-error glow-error' %>"></div>
                    <div>
                      <span class="block text-2xl sm:text-3xl font-black leading-none font-headline tracking-tighter <%= isUp ? 'text-primary' : 'text-error' %>">
                        <%= check.latencyMs %><span class="text-sm font-medium ml-1">ms</span>
                      </span>
                    </div>
                    <div class="bg-primary/5 ml-2 rounded-md text-xs font-bold font-mono px-3 py-1"><%= check.httpCode || 'ERR' %></div>
                  </div>
                  
                  <div class="text-left md:text-right space-y-2 border-t md:border-none border-primary-container/5 pt-4 md:pt-0">
                    <span class="block text-xs font-bold opacity-50 uppercase tracking-widest">Time (Local)</span>
                    <span class="block font-mono text-xs sm:text-sm font-bold text-primary"><%= new Date(check.timestamp).toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute:'2-digit', second:'2-digit'}) %></span>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } %>
        </div>
      </div>

      <!-- Recent Activity Log Section -->
      <aside class="lg:col-span-4 flex flex-col space-y-6">
        <div class="flex items-center gap-4 border-b border-primary-container/10 pb-4">
          <span class="bg-primary text-on-primary px-4 py-2 text-xs font-bold tracking-widest uppercase rounded-md">System_Log</span>
          <h2 class="font-headline font-black text-xl uppercase tracking-tighter">Raw Output</h2>
        </div>
        <div class="bg-primary-container p-6 sm:p-8 flex-1 scanline relative overflow-hidden min-h-[300px] shadow-inner rounded-md border-t border-black/20">
          <div class="relative z-10 space-y-6" id="logContainer">
            <% if (checks.length === 0) { %>
              <div class="text-on-primary-container/40 font-mono text-sm font-bold uppercase tracking-widest">AWAITING INITIALIZATION...</div>
            <% } else { %>
              <% checks.slice(0, 7).forEach(check => { %>
                <div class="flex gap-4 sm:gap-6 anim-fade items-start">
                  <span class="text-on-primary-container/40 font-mono text-xs pt-1 whitespace-nowrap">
                    <%= new Date(check.timestamp).toLocaleTimeString('en-US', {hour12:false, hour:'2-digit', minute:'2-digit', second:'2-digit'}) %>
                  </span>
                  <div class="flex-1">
                    <span class="block <%= check.status==='UP' ? 'text-secondary-fixed' : 'text-tertiary-fixed-dim' %> font-bold text-sm uppercase tracking-wide">
                      [<%= check.status %>] <%= check.httpCode || 'ERR' %>
                    </span>
                    <p class="text-on-primary-container/80 text-xs sm:text-sm font-mono mt-2 break-words leading-relaxed">
                      <%= check.url %> (<%= check.latencyMs %>ms)
                      <%= check.error ? ` ERROR_TRACE: ${check.error}` : '' %>
                    </p>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
          <!-- Decorative element -->
          <div class="absolute bottom-4 right-4 opacity-[0.03] pointer-events-none">
            <span class="material-symbols-outlined text-8xl sm:text-9xl text-on-primary-container">monitoring</span>
          </div>
        </div>
        
        <div class="bg-surface-container-high border border-primary-container/10 shadow-sm p-4 flex items-center justify-between rounded-sm">
          <span class="text-[10px] font-bold uppercase tracking-widest text-primary">Network Load</span>
          <div class="flex gap-1" id="pulseIndicator">
            <div class="h-4 w-1.5 bg-primary"></div>
            <div class="h-4 w-1.5 bg-primary"></div>
            <div class="h-4 w-1.5 bg-primary opacity-30"></div>
          </div>
        </div>
      </aside>
    </div>
  </main>

  <!-- BottomNavBar (Mobile Only) -->
  <nav class="md:hidden fixed bottom-0 left-0 w-full z-50 flex justify-around items-center bg-[#131b2e] border-t border-white/10 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.1)]">
    <button class="flex flex-col items-center justify-center text-secondary-fixed p-3 w-full">
      <span class="material-symbols-outlined mb-1">analytics</span>
      <span class="font-headline text-[10px] font-bold uppercase tracking-widest">MONITOR CORE</span>
    </button>
  </nav>

  <!-- Visual Anchor - System Footer (Desktop) -->
  <footer class="hidden md:flex fixed bottom-0 w-full bg-primary-container border-t border-white/5 text-on-primary-container/30 px-6 py-2 items-center justify-between text-[9px] font-mono uppercase tracking-[0.3em] z-50 shadow-inner">
    <span>Build: SENTINEL-V4.2.0-STABLE</span>
    <div class="flex gap-8">
      <span>Uptime: 99.999%</span>
      <span>Region: LOCAL</span>
      <span>API SENTINEL © 2024</span>
    </div>
  </footer>

  <script>
    // System logic for interacting with our backend APIs

    const form = document.getElementById('apiForm');
    const input = document.getElementById('urlInput');
    const checkBtn = document.getElementById('checkBtn');
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');

    // Live panel
    const livePanel = document.getElementById('liveResultPanel');
    const resIcon = document.getElementById('resIcon');
    const resDot = document.getElementById('resDot');
    const resCode = document.getElementById('resCode');
    const resLat = document.getElementById('resLat');
    const resLatBar = document.getElementById('resLatBar');
    const resTimestamp = document.getElementById('resTimestamp');
    const resErrBody = document.getElementById('resErrBody');

    // Agent panel
    const agentUI = document.getElementById('agentUI');
    const agentBtn = document.getElementById('agentBtn');
    const agentOut = document.getElementById('agentOut');
    const agentIcon = document.getElementById('agentIcon');
    const agentText = document.getElementById('agentText');

    let currentScanUrl = '';

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const url = input.value.trim();
      if (!url) return;
      currentScanUrl = url;

      // Reset UI state
      checkBtn.disabled = true;
      btnText.textContent = "SCANNING";
      btnIcon.textContent = "sync";
      btnIcon.classList.add("spinning");

      try {
        const res = await fetch('/check', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ url })
        });
        const data = await res.json();
        
        renderLivePanel(data);
        
        // Refresh the underlying logs by refetching HTML and replacing HTML blocks
        fetch('/')
          .then(r => r.text())
          .then(html => {
             const doc = new DOMParser().parseFromString(html, 'text/html');
             document.getElementById('historyContainer').innerHTML = doc.getElementById('historyContainer').innerHTML;
             document.getElementById('logContainer').innerHTML = doc.getElementById('logContainer').innerHTML;
             document.getElementById('historyCountLabel').textContent = doc.getElementById('historyCountLabel').textContent;
          });

      } catch (err) {
        alert("Scan Error: " + err.message);
      } finally {
        checkBtn.disabled = false;
        btnText.textContent = "Start Scan";
        btnIcon.textContent = "rocket_launch";
        btnIcon.classList.remove("spinning");
        input.value = '';
      }
    });

    function renderLivePanel(data) {
      livePanel.classList.remove('hidden');
      // re-trigger animation
      livePanel.classList.remove('anim-fade');
      void livePanel.offsetWidth;
      livePanel.classList.add('anim-fade');

      const isUp = data.status === 'UP';

      resTimestamp.textContent = new Date(data.timestamp).toLocaleTimeString('en-US');
      resCode.textContent = data.httpCode || 'ERR';
      resLat.innerHTML = `${data.latencyMs}<span class="text-sm font-medium ml-1">ms</span>`;
      
      const p = Math.min(100, Math.max(5, (data.latencyMs / 5000) * 100));
      resLatBar.style.width = `${p}%`;

      resDot.className = `w-12 h-12 rounded-full flex items-center justify-center filter drop-shadow-sm shrink-0 ${isUp ? 'bg-green-500 glow-green' : 'bg-[#ef4444] glow-error'}`;
      resIcon.textContent = isUp ? 'check_circle' : 'error';
      resCode.className = `font-mono text-3xl font-black ${isUp ? 'text-green-600' : 'text-error'}`;
      resLat.className = `font-headline text-3xl font-black ${isUp ? 'text-primary' : 'text-error'}`;
      resLatBar.className = `h-full transition-all duration-500 ease-out ${isUp ? 'bg-green-500' : 'bg-error'}`;

      if (data.error) {
        resErrBody.textContent = `CRITICAL TRACE >> ${data.error}`;
        resErrBody.classList.remove('hidden');
      } else {
        resErrBody.classList.add('hidden');
      }

      if (!isUp) {
        agentUI.classList.remove('hidden');
        agentOut.classList.add('hidden');
      } else {
        agentUI.classList.add('hidden');
      }
    }

    agentBtn.addEventListener('click', async () => {
      agentBtn.disabled = true;
      agentIcon.textContent = "sync";
      agentIcon.classList.add('spinning');
      agentText.textContent = "INITIALIZING AGENT...";
      
      try {
        const res = await fetch('/validate', {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({ url: currentScanUrl })
        });
        const data = await res.json();
        
        agentOut.classList.remove('hidden');
        let html = `> AGENT RUN COMPLETE<br>> TARGET: ${data.service}<br>> OFFICIAL STATUS: <strong class="${data.officialStatus === 'operational' ? 'text-secondary-fixed' : 'text-tertiary-fixed-dim'}">${(data.officialStatus || 'unknown').toUpperCase()}</strong><br>`;
        
        if (data.statusPageUrl) {
          html += `> SOURCE: <a href="${data.statusPageUrl}" target="_blank" class="underline text-blue-300">Status Page Link</a><br>`;
        }
        if (data.details) {
          html += `> DETAILS: ${data.details}<br>`;
        }
        if (data.error) {
          html += `> ERROR TRACE: <span class="text-tertiary-fixed-dim">${data.error}</span>`;
        }
        
        agentOut.innerHTML = html;

      } catch (err) {
        agentOut.classList.remove('hidden');
        agentOut.innerHTML = `<span class="text-tertiary-fixed-dim">> FATAL AGENT ERROR: ${err.message}</span>`;
      } finally {
         agentBtn.disabled = false;
         agentIcon.textContent = "robot_2";
         agentIcon.classList.remove('spinning');
         agentText.textContent = "Validation Complete";
      }
    });
